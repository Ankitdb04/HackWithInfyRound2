class Solution {
    Integer[][] dp;
    public int coinChange(int[] coins, int amount) {
        dp=new Integer[coins.length][amount+1];
        int ans=solve(coins.length-1,amount,coins);
        if(ans>=(int)1e9) return -1;
        return ans;
    }
    public int solve(int idx,int target,int []coins){
        if(idx==0){
            if(target% coins[0]==0){
                return target/coins[0];
            }
            return (int)1e9;
        }
        if(dp[idx][target]!=null) return dp[idx][target];
        int nontake=solve(idx-1,target,coins);
        int take=(int)1e9;
        if(target>=coins[idx]){
            take=1+solve(idx,target-coins[idx],coins);
        }
        return dp[idx][target]=Math.min(take,nontake);
    }
}
