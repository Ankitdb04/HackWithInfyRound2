class Solution {
    public int longestValidParentheses(String s) {
        int n=s.length();
        int left=0;
        int right=0;
        int max=0;
        for(int i=0;i<n;i++){
            char ch=s.charAt(i);
            if(ch=='(')left++;
            else{
                right++;
                if(left<right){
                    right=0;
                    left=0;
                }
            }
            if(left==right)max=Math.max(max,2*left);
            
        }
        left=0;
        right=0;
        for(int i=n-1;i>=0;i-- ){
            char ch=s.charAt(i);
            if(ch==')')right++;
            else{
                left++;
                if(right<left){
                    left=0;
                    right=0;
                }
            }
            if(left==right) max=Math.max(max,2*left);
        }
        return max;
    }
}
