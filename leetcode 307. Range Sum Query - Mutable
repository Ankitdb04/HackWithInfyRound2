class NumArray {
    int[] nums;
    int[] seg ;;

    public NumArray(int[] nums) {
        this.nums = nums;
        seg= new int[4 * nums.length];
        buildTree(0,0,nums.length-1);
    }

    public void update(int index, int val) {
        solve(0, index, val, 0, nums.length - 1);
    }

    public int sumRange(int left, int right) {
        return query(0, 0, nums.length - 1, left, right);
    }

    public void solve(int idx,int i,int value,int l,int r){
        if(l==r){
            seg[idx]=value;
            return;
        }
      
        int mid=l+((r-l)/2);
        if(i<=mid){
            solve(2*idx+1,i,value,l,mid);
        }else{
            solve(2*idx+2,i,value,mid+1,r);
        }
        seg[idx]=seg[idx*2+1]+seg[2*idx+2];
    }

    public int query(int idx, int l, int r, int ql, int qr) {
        if (l > qr || r < ql)
            return 0;
        if(l>=ql && r<=qr) return seg[idx];
        int mid=l+((r-l)/2);
        return query(2*idx+1,l,mid,ql,qr)+query(2*idx+2,mid+1,r,ql,qr);

    }
    public void buildTree(int idx,int l,int r){
        if(l==r){
            seg[idx]=nums[l];
            return;
        }
        int mid=l+((r-l)/2);
        buildTree(2*idx+1,l,mid);
        buildTree(2*idx+2,mid+1,r);
        seg[idx]=seg[2*idx+1]+seg[2*idx+2];
    }
}

