class Solution {
    Integer [][]dp;
    public int lengthOfLIS(int[] nums) {
        int n=nums.length;
        dp=new Integer[n][n+1];
        return solve(nums.length-1,-1,nums);
    }
    public int solve(int idx,int prev,int []nums){
        if(idx==0){
            
            if(prev==-1||nums[0]<nums[prev]) return 1;
            return 0;

        }
        if(dp[idx][prev+1]!=null) return dp[idx][prev+1];
        int take=0;
        if(prev==-1||nums[idx]<nums[prev]){
            take=1+solve(idx-1,idx,nums);
        }
        int ntake=solve(idx-1,prev,nums);
        return dp[idx][prev+1]=Math.max(take,ntake);
    }
}
