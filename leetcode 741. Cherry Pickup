class Solution {
    Integer [][][][]dp;
    public int cherryPickup(int[][] grid) {
        int n=grid.length;
        dp=new Integer[n][n][n][n];
        int ans= solve(0,0,0,0,grid);
        if(ans==Integer.MIN_VALUE)return 0;
        return ans;
    }
    public int solve(int r1,int c1,int r2,int c2,int [][]grid){
        int n=grid.length;
        if(r1>=n ||c1>=n|| r2>=n||c2>=n || grid[r1][c1]==-1 || grid[r2][c2]==-1 ) return Integer.MIN_VALUE;
        if(dp[r1][c1][r2][c2]!=null) return dp[r1][c1][r2][c2];
        if(r1==n-1 && c1==n-1 && r2==n-1 && c2==n-1) return dp[r1][c1][r2][c2]=grid[r1][c1];
        int cherry=0;
        if(r1==r2 && c1==c2){
            cherry=grid[r1][c1];

        }else{
            cherry=grid[r1][c1]+grid[r2][c2];
        }
        int rr=solve(r1,c1+1,r2,c2+1,grid);
        int dr=solve(r1+1,c1,r2,c2+1,grid);
        int rd=solve(r1,c1+1,r2+1,c2,grid);
        int dd=solve(r1+1,c1,r2+1,c2,grid);
        int ans=Math.max(rr,Math.max(dr,Math.max(rd,dd)));
        if(ans==Integer.MIN_VALUE) return dp[r1][c1][r2][c2]= ans;
        return dp[r1][c1][r2][c2]=ans+cherry;
    }
}
