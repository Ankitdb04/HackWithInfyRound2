import java.util.Scanner;
 
public class Count {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        long n = sc.nextLong();
 
        long ans = 0;
 
        for (int i = 0; i < 60; i++) {
            long bit = 1L << i;
            long cycle = bit << 1;
 
            long fullCycles = (n + 1) / cycle;
            long remaining = (n + 1) % cycle;
 
            long ones = fullCycles * bit + Math.max(0, remaining - bit);
 
            ans += ones;
        }
 
        System.out.println(ans);
    }
}
