class Solution {
    public boolean isAnagram(String s, String t) {
        int [] freqs=new int [26];
        int [] freqt=new int [26];
        int m=s.length();
        int n=t.length();
        if(m!=n) return false;
        for(int i=0;i<m;i++){
            freqs[s.charAt(i)-'a']++;
            freqt[t.charAt(i)-'a']++;
        }
        for(int i=0;i<26;i++){
            if(freqs[i]!=freqt[i]) return false;
        }
        return true;
    }
}
